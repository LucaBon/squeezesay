# Copia questi valori nelle variabili d'ambiente della Lambda (non committare i valori reali).
# URL HTTPS del tunnel verso LMS/Daphile (Cloudflare Tunnel / ngrok)
LMS_BASE_URL=https://xxxx.trycloudflare.com
# MAC del player Daphile (vedi README: comando "players")
LMS_PLAYER_ID=aa:bb:cc:dd:ee:ff
# Opzionali: credenziali se hai protetto il tunnel con Basic Auth
LMS_USERNAME=
LMS_PASSWORD=
# Servizio streaming usato dalla skill: tidal (default) o qobuz.
# Il plugin corrispondente deve essere installato e loggato su LMS/Daphile.
MUSIC_SERVICE=tidal
# --- Filtro per età / riconoscimento voce (opzionale) ---
# Il tuo personId di Alexa Voice ID (leggilo dai log CloudWatch: "personId=...").
# Vuoto = filtro disattivo. Quando parli tu accesso pieno, gli altri sono filtrati.
TRUSTED_PERSON_ID=
# Blocklist permanente di base, separata da virgole (brani e/o cantanti)
KIDSAFE_BLOCKLIST=
# Tabella DynamoDB per i termini aggiunti a voce. Su Alexa-hosted è impostata
# automaticamente (DYNAMODB_PERSISTENCE_TABLE_NAME): lascia vuoto qui.
BLOCKLIST_TABLE=
